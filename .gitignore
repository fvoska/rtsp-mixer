# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Release signing — never commit
/android/key.properties
/android/app/release.jks

# Local release artifacts
*.dmg
*.apk

# GSD (open-gsd/gsd-core) — machine-specific install state, regenerated by
# .claude/hooks/session-start.sh (settings.local.json holds absolute paths).
# The GSD payload itself (.claude/commands, agents, gsd-core, hooks/gsd-*)
# IS committed — repo-level install.
.claude/settings.local.json
.claude/gsd-file-manifest.json
.claude/gsd-install-state.json
.claude/gsd-migration-journal/
